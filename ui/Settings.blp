              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("<i>Continual </i> edge window activation on hover");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Switch edge-preview-timeout-continual {
                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }
        }

        Label {
          halign: start;
          hexpand: true;
          label: _("<b>AlbumWM Component Size Settings</b>");
          use-markup: true;
        }

        ListBox {
          focusable: false;
          selection-mode: none;
          margin-bottom: 16;

          styles [
            "frame",
          ]

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _(
                "Controls the “size” of mini-map tiles (as shown during window navigation keybinds), as compared to their actual window size (e.g. “15” corresponds to a mini-map tile size being approximately 15 % of the actual window size)"
              );
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Mini-map scale (%) <i>(0 hides Mini-map)</i>");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton minimap_scale_spin {
                width-chars: 2;
                max-width-chars: 2;
                adjustment: minimap_scale;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _(
