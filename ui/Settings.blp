using Gtk 4.0;
using Adw 1;

Adjustment horizontal-friction-adjustment {
  lower: 0;
  upper: 10;
  step-increment: 0.1;
  page-increment: 1;
}

Adjustment horizontal-sensitivity-adjustment {
  lower: 0;
  upper: 10;
  step-increment: 0.1;
  page-increment: 10;
}

Adjustment horizontal_margin {
  lower: 0;
  upper: 100;
  step-increment: 1;
  page-increment: 10;
}

Adjustment vertical-friction-adjustment {
  lower: 0;
  upper: 10;
  step-increment: 0.1;
  page-increment: 10;
}

Adjustment vertical-sensitivity-adjustment {
  lower: 0;
  upper: 10;
  step-increment: 0.1;
  page-increment: 10;
}

Adjustment vertical_margin {
  lower: 0;
  upper: 100;
  step-increment: 1;
  page-increment: 10;
}

Adjustment vertical_margin_bottom {
  lower: 0;
  upper: 100;
  step-increment: 1;
  page-increment: 10;
}

Adjustment window_gap {
  lower: 0;
  upper: 99;
  step-increment: 1;
  page-increment: 10;
}

Adjustment animation_time_adjustment {
  lower: 0.00;
  upper: 6.00;
  step-increment: 0.01;
  page-increment: 0.1;
}

Adjustment drift_speed_adjustment {
  lower: 0;
  upper: 15;
  step-increment: 1;
  page-increment: 5;
}

Adjustment drag_drift_speed_adjustment {
  lower: 0;
  upper: 15;
  step-increment: 1;
  page-increment: 5;
}

Adjustment minimap_scale {
  lower: 0;
  upper: 95;
  step-increment: 1;
  page-increment: 10;
}

Adjustment minimap_shade_opacity_scale {
  lower: 0;
  upper: 255;
  step-increment: 1;
  page-increment: 10;
}

Adjustment edge_preview_scale {
  lower: 0;
  upper: 95;
  step-increment: 1;
  page-increment: 10;
}

Adjustment edge_preview_timeout_scale {
  lower: 0;
  upper: 10000;
  step-increment: 100;
  page-increment: 1000;
}

Adjustment window_switcher_preview_scale {
  lower: 5;
  upper: 95;
  step-increment: 1;
  page-increment: 10;
}

Adjustment maximize_width_percent_scale {
  lower: 50;
  upper: 100;
  step-increment: 1;
  page-increment: 10;
}

Adjustment overview_max_window_scale {
  lower: 10;
  upper: 95;
  step-increment: 1;
  page-increment: 10;
}

Adjustment overview_min_windows_per_row {
  lower: 1;
  upper: 20;
  step-increment: 1;
  page-increment: 5;
}

Adw.PreferencesPage general_page {
  title: _("General");
  icon-name: "text-x-generic-symbolic";

  Adw.PreferencesGroup scrolledWindow {
    Viewport {
      focusable: false;
      vexpand: true;

      Box general {
        halign: center;
        margin-bottom: 16;
        orientation: vertical;
        spacing: 12;
        width-request: 580;

        Label {
          halign: start;
          hexpand: true;
          label: _("<b>Settings</b>");
          use-markup: true;
        }

        ListBox {
          focusable: false;
          selection-mode: none;
          margin-bottom: 16;

          styles [
            "frame",
          ]

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                tooltip-text: _(
                  "Sets the position when creating/inserting new tiled windows, e.g. to the right/left of the current window, or at the start/end of all tiled windows."
                );
                hexpand: true;
                label: _("Position when creating new windows");
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              ComboBoxText open-window-position {
                focusable: false;
                hexpand: false;
                width-request: 106;

                items [
                  right: _("To Right"),
                  down: _("Below"),
                ]

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Sets default focus mode used in workspaces");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Default <i>window focus mode</i> for workspaces");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              ComboBoxText default-focus-mode {
                focusable: false;
                hexpand: false;
                width-request: 106;

                items [
                  default: _("Default"),
                  center: _("Center"),
                  edge: _("Edge"),
                ]
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Show scratch windows in overview");
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              ComboBoxText scratch-in-overview {
                focusable: false;
                hexpand: false;
                width-request: 106;

                items [
                  always: _("Always"),
                  only: _("Only"),
                  never: _("Never"),
                ]

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }
        }

        Label {
          halign: start;
          hexpand: true;
          label: _("<b>Touchpad Gestures</b>");
          use-markup: true;
        }

        ListBox {
          focusable: false;
          selection-mode: none;
          margin-bottom: 16;

          styles [
            "frame",
          ]

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _(
                "Enables / disables AlbumWM gestures. Disabling this restores Gnome’s default touchpad gestures."
              );
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Enable Touchpad Gestures");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Switch gesture-enabled {
                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Sets the number of fingers used for moving the tiling viewport (windows) left/right.");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Swipe tiling windows <i>(swipe left/right)</i>");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              ComboBoxText gesture-horizontal-fingers {
                focusable: false;
                hexpand: false;
                width-request: 106;

                items [
                  fingers-disabled: _("Disabled"),
                  three-fingers: _("3 Fingers"),
                  four-fingers: _("4 Fingers"),
                ]
              }
            }
          }
        }

        Label {
          halign: start;
          hexpand: true;
          label: _("<b>Gaps | Margins</b>");
          use-markup: true;
        }

        ListBox {
          focusable: false;
          selection-mode: none;
          margin-bottom: 16;

          styles [
            "frame",
          ]

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Gap between windows");
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton window_gap_spin {
                width-chars: 2;
                max-width-chars: 2;
                adjustment: window_gap;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow general_row1 {
            activatable: false;
            focusable: false;

            Grid workspace_grid1 {
              focusable: false;
              tooltip-text: _("The minimum margin to the left and right monitor edge");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Horizontal margin");
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton hmargin_spinner {
                width-chars: 2;
                max-width-chars: 2;
                adjustment: horizontal_margin;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow general_row2 {
            activatable: false;
            focusable: false;

            Grid workspace_grid5 {
              focusable: false;
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Top margin");
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton top_margin_spinner {
                width-chars: 2;
                max-width-chars: 2;
                adjustment: vertical_margin;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Bottom margin");
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton bottom_margin_spinner {
                width-chars: 2;
                max-width-chars: 2;
                adjustment: vertical_margin_bottom;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;
            tooltip-text: _(
              "Semicolon separated values of “useful window widths” that will be cycled through. Each value is either a percentage of the available screen width (e.g. “50 %”) or a pixel size with a “px” suffix. Mixed value types are not supported."
            );

            Grid {
              focusable: false;
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Useful window widths");
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Grid {
                layout {
                  column: "1";
                  row: "0";
                }

                Button cycle_widths_reset_button {
                  margin-end: 8;
                  label: _("reset");
                  tooltip-text: _("Resets width values to the default AlbumWM width values");
                }

                Entry cycle_widths_entry {
                  width-chars: 24;
                  max-width-chars: 24;

                  layout {
                    column: "2";
                    row: "0";
                  }
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;
            tooltip-text: _(
              "Semicolon separated values of “useful window heights” that will be cycled through. Each value is either a percentage of the available screen height (e.g. “50 %”) or a pixel size with a “px” suffix. Mixed value types are not supported."
            );

            Grid {
              focusable: false;
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Useful window heights");
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Grid {
                layout {
                  column: "1";
                  row: "0";
                }

                Button cycle_heights_reset_button {
                  margin-end: 8;
                  label: _("reset");
                  tooltip-text: _("Resets height values to the default AlbumWM height values");
                }

                Entry cycle_heights_entry {
                  width-chars: 24;
                  max-width-chars: 24;

                  layout {
                    column: "1";
                    row: "0";
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

Adw.PreferencesPage keybindings_page {
  title: _("Keybindings");
  icon-name: "input-keyboard-symbolic";

  Adw.PreferencesGroup {
    $KeybindingsPane keybindings_pane {}
  }
}

Adw.PreferencesPage winprops_page {
  title: _("Winprops");
  icon-name: "sidebar-show-right-symbolic";

  Adw.PreferencesGroup {
    $WinpropsPane winpropsPane {}
  }
}

Adw.PreferencesPage advanced_page {
  title: _("Advanced");
  icon-name: "emblem-system-symbolic";

  Adw.PreferencesGroup advanced_scrolledWindow {
    Viewport {
      focusable: false;
      vexpand: true;

      Box {
        halign: center;
        margin-bottom: 16;
        orientation: vertical;
        spacing: 12;
        width-request: 580;

        Label {
          halign: start;
          hexpand: true;
          label: _("<b>Animation | Visual Settings</b>");
          use-markup: true;
        }

        ListBox {
          focusable: false;
          selection-mode: none;
          margin-bottom: 16;

          styles [
            "frame",
          ]

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _(
                "Sets the duration of AlbumWM animated transitions (e.g. switching windows, workspaces etc.). Lower values result in faster transitions."
              );
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Animation / transition time (seconds)");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton animation_time_spin {
                width-chars: 3;
                max-width-chars: 3;
                adjustment: animation_time_adjustment;
                numeric: true;
                digits: 2;
                snap-to-ticks: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Sets the drift speed (px/ms) when using “drifting view to the left/right” keybinds.");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Drift speed (px/ms) when using “viewport drift” keybinds");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton drift_speed_spin {
                width-chars: 3;
                max-width-chars: 3;
                adjustment: drift_speed_adjustment;
                numeric: true;
                snap-to-ticks: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Sets the drift speed (px/ms) when mouse is at edge of montior when dragging windows.");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Drift speed (px/ms) when dragging windows (at edge)");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton drag_drift_speed_spin {
                width-chars: 3;
                max-width-chars: 3;
                adjustment: drag_drift_speed_adjustment;
                numeric: true;
                snap-to-ticks: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Shows/hides the focus mode icon in TopBar");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Show focus mode icon");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Switch show-focus-mode-icon {
                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Shows/hides the open window position icon in TopBar");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Show open window position icon");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Switch show-open-position-icon {
                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Sets the animation when exiting GNOME overview and ensuring selected window is in view");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("GNOME overview exit <i>select window</i> animation ");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              ComboBoxText overview-ensure-viewport-animation {
                focusable: false;
                hexpand: false;
                width-request: 106;

                items [
                  none: _("None"),
                  translate: _("Translate"),
                  fade: _("Fade"),
                ]
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _(
                "Sets the minimum number of windows for each row in Gnome overview. Increasing this can make Gnome overview appear more like the current tiling layout."
              );
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("<i>Minimum</i> number of windows per GNOME overview row");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton overview_min_windows_per_row_spin {
                width-chars: 2;
                max-width-chars: 2;
                adjustment: overview_min_windows_per_row;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _(
                "Sets the opacity (between 5 and 255) of the dimming/shade used on non-selected windows during mini-map navigation."
              );
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Dimming opacity of windows during mini-map navigation");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton minimap_shade_opacity_spin {
                width-chars: 3;
                max-width-chars: 3;
                adjustment: minimap_shade_opacity_scale;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }
        }

        Label {
          halign: start;
          hexpand: true;
          label: _("<b>Tiling Edge Preview Settings</b>");
          use-markup: true;
        }

        ListBox {
          focusable: false;
          selection-mode: none;
          margin-bottom: 16;

          styles [
            "frame",
          ]

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Enables tiling edge previews");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Enable tiling edge previews");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Switch edge-preview-enable {
                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _(
                "Controls the “size” of tiling edge window previews, as compared to their actual window size (e.g. “15” corresponds to an edge preview size being approximately 15 % of the actual window size)"
              );
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Tiling edge preview scale (%)");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              SpinButton edge_scale_spin {
                width-chars: 2;
                max-width-chars: 2;
                adjustment: edge_preview_scale;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Enables activating edge window by mouse click");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Click to activate edge window");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Switch edge-preview-click-enable {
                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }

          ListBoxRow {
            activatable: false;
            focusable: false;

            Grid {
              focusable: false;
              tooltip-text: _("Enables activating edge window by hover timeout");
              margin-start: 12;
              margin-end: 12;
              margin-top: 6;
              margin-bottom: 6;
              column-spacing: 32;

              Label {
                focusable: false;
                hexpand: true;
                label: _("Hover to activate edge window");
                use-markup: true;
                xalign: 0;

                layout {
                  column: "0";
                  row: "0";
                }
              }

              Switch edge-preview-timeout-enable {
                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
