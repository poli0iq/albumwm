                adjustment: overview_max_window_scale;
                snap-to-ticks: true;
                numeric: true;
                update-policy: always;

                layout {
                  column: "1";
                  row: "0";
                }
              }
            }
          }
        }

        Label {
          halign: start;
          hexpand: true;
          label: _("<b>Other Settings</b>");
