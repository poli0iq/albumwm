                              <object class="GtkLabel">
                                <property name="focusable">False</property>
                                <property name="tooltip_text" translatable="yes">Sets the position when creating/inserting new tiled windows, e.g. to the right/left of the current window, or at the start/end of all tiled windows.</property>
